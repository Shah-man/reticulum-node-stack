}

# Просмотр лог-файла с пагинацией
view_log_file() {
    local log_file="$1"
    local title="$2"
    
    if [ ! -f "$log_file" ]; then
        echo ""
        echo -e "${YELLOW}Лог-файл не найден или пуст${NC}"
        press_enter
        return
    fi
    
    local lines=$(wc -l < "$log_file")
    if [ "$lines" -eq 0 ]; then
        echo ""
        echo -e "${YELLOW}Лог пуст${NC}"
        press_enter
        return
    fi
    
    local page_size=30
    local total_pages=$(( (lines + page_size - 1) / page_size ))
    local current_page=1
    
    while true; do
        clear
        echo ""
        echo -e "${CYAN}═══ $title ═══${NC}"
        echo -e "${GRAY}Всего: $lines записей | Страница $current_page/$total_pages${NC}"
        echo -e "${GRAY}[n] след. | [p] пред. | [f] первая | [l] последняя | [0] выход${NC}"
        print_line
        echo ""
        
        local start_line=$(( (current_page - 1) * page_size + 1 ))
        sed -n "${start_line},+$((page_size - 1))p" "$log_file"
        
        echo ""
        print_line
        echo -ne "${CYAN}Выбор: ${NC}"
        local choice=$(read_key)
        
        if [[ "$choice" == "ESC" ]] || [[ "$choice" == "0" ]]; then
            return
        fi
        
        choice=$(convert_ru_to_en "$choice")
        
        case $choice in
            n|N) 
                if [ "$current_page" -lt "$total_pages" ]; then
                    ((current_page++))
                fi
                ;;
            p|P)
                if [ "$current_page" -gt 1 ]; then
                    ((current_page--))
                fi
                ;;
            f|F) current_page=1 ;;
            l|L) current_page=$total_pages ;;
            *) ;;
        esac
    done
}

# Меню управления доверенными
menu_trusted_users() {
    local bot_db="/home/user/ollama-bot/bot_data"
    
    while true; do
        print_header
        echo -e "${WHITE}${BOLD}  👥 ДОВЕРЕННЫЕ ПОЛЬЗОВАТЕЛИ${NC}"
        print_line
        echo ""
        echo -e "${GRAY}Доверенные могут создавать/удалять свои группы${NC}"
        echo ""
        
        # Показываем текущий список
        if [ -f "$bot_db" ]; then
            local trusted=$(sqlite3 "$bot_db" "SELECT value FROM key_value WHERE key='trusted_users'" 2>/dev/null)
            if [ -n "$trusted" ] && [ "$trusted" != "[]" ]; then
                echo -e "${WHITE}Текущий список:${NC}"
                echo "$trusted" | "$VENV_PATH/bin/python3" -c "
import sys, json
data = json.loads(sys.stdin.read())
for i, h in enumerate(data, 1):
    print(f'  {i}. {h}')
print(f'\n  Всего: {len(data)}')
" 2>/dev/null || echo -e "  ${GRAY}Ошибка чтения${NC}"
            else
                echo -e "  ${YELLOW}Список пуст${NC}"
            fi
        else
            echo -e "  ${RED}База данных не найдена${NC}"
        fi
        
        echo ""
        print_line
        echo -e "  ${LIGHT_GREEN}[1]${NC} ➕ ${LIGHT_GREEN}Добавить пользователя${NC}"
        echo -e "  ${LIGHT_RED}[2]${NC} ➖ ${LIGHT_RED}Удалить пользователя${NC}"
        echo -e "  ${LIGHT_CYAN}[3]${NC} 🔄 ${LIGHT_CYAN}Обновить список${NC}"
        echo -e "  ${LIGHT_PURPLE}[4]${NC} 📋 ${LIGHT_PURPLE}Показать команды бота${NC}"
        print_line
        echo -e "  ${GRAY}[ESC/0]${NC} ${GRAY}← Назад${NC}"
        echo ""
        
        echo -ne "${CYAN}Выбор: ${NC}"
        local choice=$(read_key)
        echo "$choice"
        
        if [[ "$choice" == "ESC" ]] || [[ "$choice" == "0" ]]; then
            return
        fi
        
        choice=$(convert_ru_to_en "$choice")
        
        case $choice in
            1) add_trusted_user ;;
            2) remove_trusted_user ;;
            3) ;; # просто обновит экран
            4) show_bot_commands ;;
            *) ;;
        esac
    done
}

