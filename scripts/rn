# Редактирование данных группы (название, описание, участники)
edit_group_config() {
    local config_file="/root/.config/lxmf_distribution_group_extended/data.cfg"
    
    echo ""
    echo -e "${CYAN}═══ ДАННЫЕ ГРУППЫ ═══${NC}"
    echo ""
    
    if [ -f "$config_file" ]; then
        local lines=$(wc -l < "$config_file")
        local size=$(du -h "$config_file" | cut -f1)
        echo -e "  📄 Файл: ${WHITE}$config_file${NC}"
        echo -e "  📊 Строк: ${WHITE}$lines${NC}  Размер: ${WHITE}$size${NC}"
        echo ""
    else
        echo -e "  ${RED}✗ Файл не найден!${NC}"
        press_enter
        return
    fi
    
    echo -e "${YELLOW}⚠ Здесь: название, описание, участники группы${NC}"
    echo -e "${GRAY}Открываю nano для редактирования...${NC}"
    echo -e "${GRAY}(Ctrl+O сохранить, Ctrl+X выход)${NC}"
    sleep 1
    
    sudo nano "$config_file"
    
    echo ""
    echo -e "${GREEN}✓ Редактирование завершено${NC}"
    echo -e "${YELLOW}Не забудь перезапустить группу для применения изменений!${NC}"
    press_enter
}

