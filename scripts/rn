menu_group() {
    local service="surgut_group.service"
    local name="${SERVICE_NAMES[$service]}"
    local config_path="/root/.config/lxmf_distribution_group_extended"
    
    while true; do
        print_header
        echo -e "${WHITE}${BOLD}  $name${NC}"
        print_line
        echo ""
        print_service_status "$service"
        echo ""
        print_line
        echo -e "  ${GREEN}[1]${NC} ▶ ${GREEN}Запустить${NC}"
        echo -e "  ${RED}[2]${NC} ■ ${RED}Остановить${NC}"
        echo -e "  ${YELLOW}[3]${NC} ↻ ${YELLOW}Перезапустить${NC}"
        echo -e "  ${LIGHT_CYAN}[4]${NC} 📜 ${LIGHT_CYAN}Показать логи${NC}"
        echo -e "  ${LIGHT_BLUE}[5]${NC} ℹ️  ${LIGHT_BLUE}Подробный статус${NC}"
        echo -e "  ${LIGHT_PURPLE}[6]${NC} 👥 ${LIGHT_PURPLE}Участники группы${NC}"
        echo -e "  ${PINK}[7]${NC} 📌 ${PINK}Закреплённое сообщение${NC}"
        echo -e "  ${ORANGE}[8]${NC} 📊 ${ORANGE}Статистика группы${NC}"
        echo -e "  ${LIGHT_GREEN}[9]${NC} ✉️  ${LIGHT_GREEN}Отправить сообщение${NC}"
        print_line
        echo -e "  ${LIGHT_RED}[d]${NC} 📝 ${LIGHT_RED}Редактировать data.cfg${NC}"
        echo -e "  ${LIGHT_PURPLE}[c]${NC} ⚙️  ${LIGHT_PURPLE}Редактировать config.cfg${NC}"
        echo -e "  ${YELLOW}[o]${NC} 📋 ${YELLOW}Редактировать config.cfg.owr${NC}"
        print_line
        echo -e "  ${GRAY}[0]${NC} ${GRAY}← Назад / Enter${NC}"
        echo ""
        
        echo -ne "${CYAN}Выбор: ${NC}"
        local choice=$(read_key)
        echo "$choice"
        
        # Проверяем ESC
        if [[ "$choice" == "ESC" ]]; then
            return
        fi
        
        choice=$(convert_ru_to_en "$choice")
        
        case $choice in
            1) start_service "$service"; press_enter ;;
            2) 
                if verify_pin "остановить группу"; then
                    stop_service "$service"
                    press_enter
                fi
                ;;
            3) restart_service "$service"; press_enter ;;
            4)
                echo ""
                echo -e "${CYAN}═══ ЛОГИ: $name (Ctrl+C для выхода) ═══${NC}"
                sudo journalctl -u "$service" -f --no-pager -n 50
                ;;
            5)
                echo ""
                sudo systemctl status "$service"
                press_enter
                ;;
            6) show_group_members ;;
            7) show_group_pin ;;
            8) show_group_stats ;;
            9) 
                if verify_pin "отправить сообщение"; then
                    send_group_message
                fi
                ;;
            d|D)
                if verify_pin "редактировать data.cfg"; then
                    edit_group_config
                fi
                ;;
            c|C)
                if verify_pin "редактировать config.cfg"; then
                    edit_surgut_config_cfg
                fi
                ;;
            o|O)
                if verify_pin "редактировать config.cfg.owr"; then
                    edit_group_settings
                fi
                ;;
            0) return ;;
            q|Q) echo -e "\n${CYAN}Скрипт завершён.${NC}\n"; exit 0 ;;
            *) ;;
        esac
    done
}

# Отправка сообщения в группу
send_group_message() {
    while true; do
        echo ""
        echo -e "${CYAN}═══ ОТПРАВКА СООБЩЕНИЯ В ГРУППУ ═══${NC}"
        echo ""
        echo -e "${GRAY}Сообщение будет отправлено всем участникам от имени группы${NC}"
        echo ""
        
        echo -ne "${WHITE}Введите сообщение (или Enter для выхода): ${NC}"
        read -e -r message
        
        if [ -z "$message" ]; then
            return
        fi
        
        # Показываем сообщение для подтверждения
        echo ""
        echo -e "${WHITE}Сообщение:${NC} $message"
        echo ""
        echo -ne "${YELLOW}Отправить? (Enter = да, n = нет): ${NC}"
        read -r confirm
        
        # Пустой ввод (Enter) = да, n/N/т/Т = нет
        if [[ "$confirm" =~ ^[NnТт]$ ]]; then
            echo -e "${YELLOW}Отменено${NC}"
            continue
        fi
        
        # Сохраняем сообщение во временный файл в UTF-8
        printf '%s' "$message" | iconv -t UTF-8 > /tmp/group_message.txt 2>/dev/null || echo "$message" > /tmp/group_message.txt
        
        echo ""
        echo -e "${YELLOW}Останавливаю группу...${NC}"
        systemctl stop surgut_group.service
        sleep 1
        
        echo -e "${YELLOW}Отправляю...${NC}"
        
        # Отправляем сообщение
        "$VENV_PATH/bin/python3" /tmp/send_group_msg.py
        
        echo -e "${YELLOW}Запускаю группу...${NC}"
        systemctl start surgut_group.service
        
        # Удаляем временный файл
        rm -f /tmp/group_message.txt 2>/dev/null
        
        echo ""
        echo -e "${GREEN}✓ Готово!${NC}"
        echo ""
        echo -ne "${GRAY}Отправить ещё? (y = да, Enter = выход): ${NC}"
        read -r again
        
        if [[ ! "$again" =~ ^[YyДдНн]$ ]]; then
            return
        fi
    done
}

# Создаём Python скрипт для отправки (вызывается из send_group_message)
create_send_script() {
    cat > /tmp/send_group_msg.py << 'PYEOF'
# -*- coding: utf-8 -*-
import RNS
import LXMF
import time
import configparser

# Пути
GROUP_IDENTITY = "/root/.config/lxmf_distribution_group_extended/identity"
GROUP_DATA = "/root/.config/lxmf_distribution_group_extended/data.cfg"
GROUP_STORAGE = "/root/.config/lxmf_distribution_group_extended"
MESSAGE_FILE = "/tmp/group_message.txt"

# Читаем сообщение (пробуем разные кодировки)
message = None
for encoding in ['utf-8', 'cp1251', 'latin-1']:
    try:
        with open(MESSAGE_FILE, 'r', encoding=encoding) as f:
            message = f.read().strip()
        break
    except:
        continue

if not message:
    print("Ошибка: не удалось прочитать сообщение")
    exit(1)

print(f"Сообщение: {message}")

# Инициализация Reticulum
reticulum = RNS.Reticulum()

# Загружаем identity группы
identity = RNS.Identity.from_file(GROUP_IDENTITY)

# Создаём LXMF Router
router = LXMF.LXMRouter(identity=identity, storagepath=GROUP_STORAGE)
group_dest = router.register_delivery_identity(identity, display_name="")

# Читаем участников группы
config = configparser.ConfigParser()
config.read(GROUP_DATA)

recipients = []

# Собираем админов и пользователей
for section in ['admin', 'user']:
    if section in config.sections():
        for hash_addr in config[section]:
            recipients.append(hash_addr)

print(f"Получателей: {len(recipients)}")

sent = 0
failed = 0

for dest_hash in recipients:
    try:
        dest_hash_bytes = bytes.fromhex(dest_hash)
        dest_identity = RNS.Identity.recall(dest_hash_bytes)
        
        if dest_identity:
            dest = RNS.Destination(
                dest_identity,
                RNS.Destination.OUT,
                RNS.Destination.SINGLE,
                "lxmf", "delivery"
            )
            
            lxm = LXMF.LXMessage(dest, group_dest, message, title="", desired_method=LXMF.LXMessage.DIRECT)
            lxm.try_propagation_on_fail = True
            router.handle_outbound(lxm)
            sent += 1
            print(f"✓ {dest_hash[:8]}...")
        else:
            RNS.Transport.request_path(dest_hash_bytes)
            failed += 1
            print(f"? {dest_hash[:8]}... (путь запрошен)")
    except Exception as e:
        failed += 1
        print(f"✗ {dest_hash[:8]}...: {e}")

# Ждём отправку
time.sleep(10)
    
print(f"Отправлено: {sent}")
PYEOF
}

# Создаём скрипт при загрузке
create_send_script

# Участники группы
show_group_members() {
    echo ""
    echo -e "${CYAN}═══ УЧАСТНИКИ ГРУППЫ ═══${NC}"
    echo ""
    
    local data_file="/root/.config/lxmf_distribution_group_extended/data.cfg"
    
    if [ -f "$data_file" ]; then
        # Парсим через Python — надёжнее
        sudo "$VENV_PATH/bin/python3" << 'PYEOF'
import configparser
import os

data_file = "/root/.config/lxmf_distribution_group_extended/data.cfg"
config = configparser.ConfigParser()
config.read(data_file)

# Админы
if 'admin' in config.sections():
    admins = dict(config['admin'])
    if admins:
        print("  \033[1;31m👑 АДМИНЫ:\033[0m")
        for hash_addr, nick in admins.items():
            nick = nick.strip() if nick.strip() else hash_addr[:8]
            print(f"     \033[1;37m{nick}\033[0m \033[0;90m[{hash_addr}]\033[0m")
        print()

# Пользователи
if 'user' in config.sections():
    users = dict(config['user'])
    if users:
        print("  \033[1;32m👤 ПОЛЬЗОВАТЕЛИ:\033[0m")
        for hash_addr, nick in users.items():
            nick = nick.strip() if nick.strip() else hash_addr[:8]
            print(f"     \033[1;37m{nick}\033[0m \033[0;90m[{hash_addr}]\033[0m")
        print()

# Заблокированные
if 'block_user' in config.sections():
    blocked = dict(config['block_user'])
    if blocked:
        print("  \033[0;31m🚫 ЗАБЛОКИРОВАНЫ:\033[0m")
        for hash_addr, nick in blocked.items():
            nick = nick.strip() if nick.strip() else hash_addr[:8]
            print(f"     \033[0;90m{nick} [{hash_addr}]\033[0m")
PYEOF
    else
        echo -e "  ${RED}Файл данных не найден${NC}"
    fi
    
    press_enter
}

# Закреплённое сообщение
show_group_pin() {
    echo ""
    echo -e "${CYAN}═══ ЗАКРЕПЛЁННОЕ СООБЩЕНИЕ ═══${NC}"
    echo ""
    
    local data_file="/root/.config/lxmf_distribution_group_extended/data.cfg"
    
    if [ -f "$data_file" ]; then
        local in_pin=0
        while IFS= read -r line; do
            if [[ "$line" == "[pin]" ]]; then
                in_pin=1
                continue
            fi
            if [[ "$line" == "["* ]] && [ $in_pin -eq 1 ]; then
                break
            fi
            if [ $in_pin -eq 1 ] && [ -n "$line" ]; then
                echo -e "  ${WHITE}$line${NC}"
            fi
        done < "$data_file"
    else
        echo -e "  ${RED}Файл данных не найден${NC}"
    fi
    
    press_enter
}

# Статистика группы
show_group_stats() {
    echo ""
    echo -e "${CYAN}═══ СТАТИСТИКА ГРУППЫ ═══${NC}"
    echo ""
    
    local data_file="/root/.config/lxmf_distribution_group_extended/data.cfg"
    
    # Парсим через Python
    sudo "$VENV_PATH/bin/python3" << 'PYEOF'
import configparser

data_file = "/root/.config/lxmf_distribution_group_extended/data.cfg"
config = configparser.ConfigParser()
config.read(data_file)

admins = len(dict(config['admin'])) if 'admin' in config.sections() else 0
users = len(dict(config['user'])) if 'user' in config.sections() else 0
blocked = len(dict(config['block_user'])) if 'block_user' in config.sections() else 0

print(f"  👑 Админов: \033[1;37m{admins}\033[0m")
print(f"  👤 Пользователей: \033[1;37m{users}\033[0m")
print(f"  🚫 Заблокировано: \033[1;37m{blocked}\033[0m")
print(f"  📊 Всего участников: \033[1;37m{admins + users}\033[0m")
PYEOF
    
    echo ""
    
    local stat_file="/root/.config/lxmf_distribution_group_extended/statistic.cfg"
    if [ -f "$stat_file" ]; then
        sudo "$VENV_PATH/bin/python3" << 'PYEOF'
import configparser

stat_file = "/root/.config/lxmf_distribution_group_extended/statistic.cfg"
config = configparser.ConfigParser()
config.read(stat_file)

if 'interface_received_3' in config.sections():
    today = config['interface_received_3'].get('day_value', '0')
    total = config['interface_received_3'].get('all_value', '0')
    print(f"  📨 Сообщений сегодня: \033[1;37m{today}\033[0m")
    print(f"  📬 Сообщений всего: \033[1;37m{total}\033[0m")
PYEOF
    fi
    
    echo ""
    
    # Ресурсы
    local pid=$(systemctl show -p MainPID surgut_group.service 2>/dev/null | cut -d= -f2)
    if [ "$pid" != "0" ] && [ -n "$pid" ]; then
        echo -e "  ${GRAY}Ресурсы (PID: $pid):${NC}"
        ps -p "$pid" -o %cpu,%mem,rss --no-headers 2>/dev/null | \
            awk '{printf "  CPU: %s%%  MEM: %s%%  RAM: %.1f MB\n", $1, $2, $3/1024}'
    fi
    
    press_enter
}

# ══════════════════════════════════════════════════════════════════
# ИНТЕРАКТИВНЫЙ ЗАПУСК NOMADNET
# ══════════════════════════════════════════════════════════════════

launch_nomadnet_interactive() {
    echo ""
    
    # Проверяем, запущен ли демон
    if [ "$(get_service_status "nomadnet.service")" = "active" ]; then
        echo -e "${YELLOW}■${NC} Останавливаю демон для интерактивного режима..."
        sudo systemctl stop nomadnet.service
        sleep 1
    fi
    
    echo ""
    echo -e "${CYAN}═══ ЗАПУСК NOMADNET ИНТЕРАКТИВНО ═══${NC}"
    echo -e "${GRAY}Для выхода нажми Ctrl+C или Q внутри NomadNet${NC}"
    echo ""
    sleep 1
    
    # Запускаем интерактивно
    "$VENV_PATH/bin/nomadnet"
    
    # После выхода автоматически запускаем демон
    echo ""
    echo -e "${YELLOW}▶${NC} Запускаю NomadNet демон..."
    start_service "nomadnet.service"
    press_enter
}

