# Редактирование базы знаний бота
menu_knowledge_base() {
    local kb_dir="/home/user/ollama-bot/knowledge"
    local topics_file="$kb_dir/topics.json"
    
    while true; do
        print_header
        echo -e "${WHITE}${BOLD}  📚 БАЗА ЗНАНИЙ${NC}"
        print_line
        echo ""
        
        # Показываем файлы базы знаний
        echo -e "${WHITE}Файлы тем:${NC}"
        local files=()
        local i=1
        for f in "$kb_dir"/*.txt; do
            if [ -f "$f" ]; then
                local fname=$(basename "$f")
                local fsize=$(du -h "$f" 2>/dev/null | cut -f1)
                local flines=$(wc -l < "$f" 2>/dev/null)
                files+=("$f")
                echo -e "  ${LIGHT_CYAN}[$i]${NC} $fname ${GRAY}($flines строк, $fsize)${NC}"
                ((i++))
            fi
        done
        
        if [ ${#files[@]} -eq 0 ]; then
            echo -e "  ${YELLOW}Нет файлов тем${NC}"
        fi
        
        echo ""
        print_line
        echo -e "  ${LIGHT_GREEN}[+]${NC} ➕ ${LIGHT_GREEN}Добавить новую тему${NC}"
        echo -e "  ${LIGHT_PURPLE}[k]${NC} 🔑 ${LIGHT_PURPLE}Ключевые слова (topics.json)${NC}"
        echo -e "  ${LIGHT_RED}[d]${NC} 🗑️  ${LIGHT_RED}Удалить тему${NC}"
        print_line
        echo -e "  ${GRAY}[ESC/0]${NC} ${GRAY}← Назад${NC}"
        echo ""
        
        echo -ne "${CYAN}Выбор: ${NC}"
        local choice=$(read_key)
        echo "$choice"
        
        if [[ "$choice" == "ESC" ]] || [[ "$choice" == "0" ]]; then
            return
        fi
        
        choice=$(convert_ru_to_en "$choice")
        
        case $choice in
            +)
                echo ""
                echo -e "${GRAY}(Enter или 0 = отмена)${NC}"
                echo -ne "${CYAN}Имя файла (без .txt): ${NC}"
                read -r newname
                if [ -z "$newname" ] || [ "$newname" == "0" ]; then
                    echo -e "${GRAY}Отменено${NC}"
                    sleep 1
                    continue
                fi
                local newfile="$kb_dir/${newname}.txt"
                echo "=== $(echo "$newname" | tr '[:lower:]' '[:upper:]') ===" > "$newfile"
                echo "" >> "$newfile"
                sudo nano "$newfile"
                echo -e "${GREEN}✓ Файл создан: ${newname}.txt${NC}"
                echo -e "${YELLOW}⚠ Не забудь добавить ключевые слова в topics.json!${NC}"
                sleep 2
                ;;
            k|K)
                echo ""
                echo -e "${CYAN}═══ КЛЮЧЕВЫЕ СЛОВА ═══${NC}"
                echo ""
                if [ -f "$topics_file" ]; then
                    cat "$topics_file" | python3 -m json.tool 2>/dev/null || cat "$topics_file"
                else
                    echo -e "${YELLOW}Файл topics.json не найден${NC}"
                fi
                echo ""
                echo -ne "${CYAN}Редактировать? (y/n): ${NC}"
                read -r edit_confirm
                if [[ "$edit_confirm" =~ ^[yYдД]$ ]]; then
                    sudo nano "$topics_file"
                    echo -e "${GREEN}✓ Сохранено${NC}"
                fi
                sleep 1
                ;;
            d|D)
                echo ""
                echo -ne "${RED}Номер файла для удаления (0=отмена): ${NC}"
                read -r del_num
                if [[ "$del_num" =~ ^[0-9]+$ ]] && [ "$del_num" -ge 1 ] && [ "$del_num" -le "${#files[@]}" ]; then
                    local del_file="${files[$((del_num-1))]}"
                    local del_name=$(basename "$del_file")
                    echo -ne "${RED}Удалить $del_name? (y/n): ${NC}"
                    read -r confirm
                    if [[ "$confirm" =~ ^[yYдД]$ ]]; then
                        rm -f "$del_file"
                        echo -e "${GREEN}✓ Удалено${NC}"
                        echo -e "${YELLOW}⚠ Не забудь убрать из topics.json!${NC}"
                        sleep 2
                    fi
                fi
                ;;
            *)
                # Редактирование выбранного файла
                if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#files[@]}" ]; then
                    local selected="${files[$((choice-1))]}"
                    sudo nano "$selected"
                    echo -e "${GREEN}✓ Сохранено${NC}"
                    sleep 1
                fi
                ;;
        esac
    done
}

# Редактирование кода бота (промпт и логика AI)
edit_bot_code() {
    local bot_file="/home/user/ollama-bot/cogs/ai.py"
    
    echo ""
    echo -e "${CYAN}═══ ПРОМПТ И ЛОГИКА БОТА ═══${NC}"
    echo ""
    
    if [ -f "$bot_file" ]; then
        local lines=$(wc -l < "$bot_file")
        local size=$(du -h "$bot_file" | cut -f1)
        echo -e "  📄 Файл: ${WHITE}$bot_file${NC}"
        echo -e "  📊 Строк: ${WHITE}$lines${NC}  Размер: ${WHITE}$size${NC}"
        echo ""
    else
        echo -e "  ${RED}✗ Файл не найден!${NC}"
        press_enter
        return
    fi
    
    echo -e "${YELLOW}⚠ Внимание: изменение кода может сломать бота!${NC}"
    echo -e "${GRAY}Открываю nano для редактирования...${NC}"
    echo -e "${GRAY}(Ctrl+O сохранить, Ctrl+X выход)${NC}"
    sleep 1
    
    sudo nano "$bot_file"
    
    echo ""
    echo -e "${GREEN}✓ Редактирование завершено${NC}"
    echo -e "${YELLOW}Не забудь перезапустить бота для применения изменений!${NC}"
    press_enter
}

# Редактирование настроек бота (.env)
edit_bot_settings() {
    local env_file="/home/user/ollama-bot/.env"
    
    echo ""
    echo -e "${CYAN}═══ НАСТРОЙКИ БОТА (.env) ═══${NC}"
    echo ""
    
    if [ -f "$env_file" ]; then
        echo -e "${WHITE}Текущие настройки:${NC}"
        echo ""
        while IFS='=' read -r key value; do
            [[ -z "$key" || "$key" =~ ^# ]] && continue
            case "$key" in
                BOT_NAME) echo -e "  📛 Имя бота: ${WHITE}$value${NC}" ;;
                ADMIN_HASHES) echo -e "  👑 Админ: ${WHITE}${value:0:16}...${NC}" ;;
                OLLAMA_MODEL) echo -e "  🤖 Модель: ${WHITE}$value${NC}" ;;
                MAX_HISTORY) echo -e "  💾 Память: ${WHITE}$value сообщений${NC}" ;;
                ANNOUNCE_INTERVAL) echo -e "  📢 Анонс: ${WHITE}$((value/60)) мин${NC}" ;;
                RATE_LIMIT) echo -e "  ⏱️ Лимит: ${WHITE}$value сообщ/мин${NC}" ;;
                COOLDOWN) echo -e "  ⏳ Кулдаун: ${WHITE}$value сек${NC}" ;;
                PROPAGATION_NODE) echo -e "  📡 Propagation: ${WHITE}${value:0:16}...${NC}" ;;
            esac
        done < "$env_file"
        echo ""
    else
        echo -e "  ${RED}✗ Файл не найден!${NC}"
        press_enter
        return
    fi
    
    echo -e "${GRAY}Открываю nano для редактирования...${NC}"
    echo -e "${GRAY}(Ctrl+O сохранить, Ctrl+X выход)${NC}"
    sleep 1
    
    sudo nano "$env_file"
    
    echo ""
    echo -e "${GREEN}✓ Редактирование завершено${NC}"
    echo -e "${YELLOW}Не забудь перезапустить бота для применения изменений!${NC}"
    press_enter
}

