# Меню логов сообщений бота (УЛУЧШЕННАЯ ВЕРСИЯ)
menu_bot_logs() {
    local logs_dir="/home/user/ollama-bot/logs"
    local msg_log="$logs_dir/messages.log"
    
    while true; do
        print_header
        echo -e "${WHITE}${BOLD}  📋 ЛОГИ СООБЩЕНИЙ${NC}"
        print_line
        echo ""
        
        # Показываем размеры логов
        if [ -d "$logs_dir" ]; then
            echo -e "${WHITE}Файлы логов:${NC}"
            if [ -f "$logs_dir/admin.log" ]; then
                local admin_size=$(du -h "$logs_dir/admin.log" 2>/dev/null | cut -f1)
                local admin_lines=$(wc -l < "$logs_dir/admin.log" 2>/dev/null || echo "0")
                echo -e "  📄 admin.log:    ${WHITE}$admin_lines строк${NC} ($admin_size)"
            else
                echo -e "  📄 admin.log:    ${GRAY}не создан${NC}"
            fi
            if [ -f "$msg_log" ]; then
                local msg_size=$(du -h "$msg_log" 2>/dev/null | cut -f1)
                local msg_lines=$(wc -l < "$msg_log" 2>/dev/null || echo "0")
                local unique_users=$(cut -d'|' -f3 "$msg_log" 2>/dev/null | tr -d ' ' | sort -u | wc -l)
                echo -e "  📄 messages.log: ${WHITE}$msg_lines строк${NC} ($msg_size)"
                echo -e "  👥 Уникальных пользователей: ${WHITE}$unique_users${NC}"
            else
                echo -e "  📄 messages.log: ${GRAY}не создан${NC}"
            fi
            echo ""
            echo -e "${GRAY}Хранение: 19 дней, затем автоочистка${NC}"
        else
            echo -e "  ${YELLOW}Директория логов не создана${NC}"
            echo -e "  ${GRAY}Логи появятся после первого сообщения боту${NC}"
        fi
        
        echo ""
        print_line
        echo -e "  ${LIGHT_CYAN}[1]${NC} 👤 ${LIGHT_CYAN}Логи админа (мои)${NC}"
        echo -e "  ${LIGHT_GREEN}[2]${NC} 👥 ${LIGHT_GREEN}Список пользователей${NC}"
        echo -e "  ${LIGHT_PURPLE}[3]${NC} 🔍 ${LIGHT_PURPLE}Поиск по нику${NC}"
        echo -e "  ${LIGHT_BLUE}[4]${NC} 🔎 ${LIGHT_BLUE}Поиск по адресу${NC}"
        echo -e "  ${ORANGE}[5]${NC} 📜 ${ORANGE}Все сообщения${NC}"
        echo -e "  ${LIGHT_RED}[6]${NC} 🗑️  ${LIGHT_RED}Очистить все логи${NC}"
        print_line
        echo -e "  ${GRAY}[ESC/0]${NC} ${GRAY}← Назад${NC}"
        echo ""
        
        echo -ne "${CYAN}Выбор: ${NC}"
        local choice=$(read_key)
        echo "$choice"
        
        if [[ "$choice" == "ESC" ]] || [[ "$choice" == "0" ]]; then
            return
        fi
        
        choice=$(convert_ru_to_en "$choice")
        
        case $choice in
            1) view_admin_logs ;;
            2) show_users_list ;;
            3) search_by_nick ;;
            4) search_by_address ;;
            5) show_last_messages ;;
            6)
                if verify_pin "очистить логи"; then
                    echo ""
                    echo -ne "${RED}Удалить все логи? (y/n): ${NC}"
                    read -r confirm
                    if [[ "$confirm" =~ ^[yYдД]$ ]]; then
                        rm -f "$logs_dir/admin.log" "$logs_dir/messages.log" 2>/dev/null
                        echo -e "${GREEN}✓ Логи очищены${NC}"
                    else
                        echo -e "${GRAY}Отменено${NC}"
                    fi
                    sleep 1
                fi
                ;;
            *) ;;
        esac
    done
}

# Показать список пользователей
show_users_list() {
    local msg_log="/home/user/ollama-bot/logs/messages.log"
    
    while true; do
        print_header
        echo -e "${WHITE}${BOLD}  👥 СПИСОК ПОЛЬЗОВАТЕЛЕЙ${NC}"
        print_line
        echo ""
        
        if [ ! -f "$msg_log" ]; then
            echo -e "  ${YELLOW}Лог не найден${NC}"
            press_enter
            return
        fi
        
        # Получаем уникальные адреса с количеством сообщений
        local users=()
        local i=1
        
        # Читаем в массив без подпроцесса
        while IFS= read -r line; do
            local hash=$(echo "$line" | cut -d' ' -f1)
            local count=$(echo "$line" | cut -d' ' -f2)
            local nick=$(get_user_nick "$hash")
            users+=("$hash")
            
            # Цветовая индикация активности
            local color="${GRAY}"
            if [ "$count" -gt 100 ]; then
                color="${LIGHT_GREEN}"
            elif [ "$count" -gt 50 ]; then
                color="${LIGHT_CYAN}"
            elif [ "$count" -gt 10 ]; then
                color="${WHITE}"
            fi
            
            printf "  ${LIGHT_CYAN}[%2d]${NC} ${WHITE}%s${NC} ${GRAY}[%s]${NC} ${color}%d сообщ.${NC}\n" "$i" "$nick" "$hash" "$count"
            ((i++))
        done < <(cut -d'|' -f3 "$msg_log" 2>/dev/null | tr -d ' ' | sort | uniq -c | sort -rn | awk '{print $2, $1}')
        
        if [ ${#users[@]} -eq 0 ]; then
            echo -e "  ${YELLOW}Пользователей не найдено${NC}"
            press_enter
            return
        fi
        
        echo ""
        print_line
        echo -e "  ${GRAY}Введи номер для просмотра переписки${NC}"
        echo -e "  ${GRAY}[0/Enter]${NC} ${GRAY}← Назад${NC}"
        echo ""
        
        echo -ne "${CYAN}Номер: ${NC}"
        read -r choice
        
        if [[ -z "$choice" ]] || [[ "$choice" == "0" ]]; then
            return
        fi
        
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#users[@]}" ]; then
            local selected_hash="${users[$((choice-1))]}"
            view_user_messages "$selected_hash"
        fi
    done
}

# Просмотр сообщений пользователя с пагинацией
view_user_messages() {
    local user_hash="$1"
    local msg_log="/home/user/ollama-bot/logs/messages.log"
    local nick=$(get_user_nick "$user_hash")
    local page_size=20
    
    if [ ! -f "$msg_log" ]; then
        echo -e "  ${YELLOW}Лог не найден${NC}"
        press_enter
        return
    fi
    
    # Создаём временный файл с сообщениями пользователя
    local tmp_file="/tmp/user_messages_$$"
    grep "$user_hash" "$msg_log" > "$tmp_file"
    
    local total_lines=$(wc -l < "$tmp_file")
    if [ "$total_lines" -eq 0 ]; then
        echo -e "  ${YELLOW}Сообщений не найдено${NC}"
        rm -f "$tmp_file"
        press_enter
        return
    fi
    
    local total_pages=$(( (total_lines + page_size - 1) / page_size ))
    local current_page=$total_pages  # Начинаем с последней страницы (новые сообщения)
    
    while true; do
        clear
        echo ""
        echo -e "${CYAN}═══ 💬 ПЕРЕПИСКА С ${WHITE}${nick}${CYAN} ═══${NC}"
        echo -e "${GRAY}Адрес: ${user_hash}${NC}"
        echo -e "${GRAY}Всего: $total_lines сообщений | Страница $current_page/$total_pages${NC}"
        echo -e "${GRAY}[n] след. | [p] пред. | [f] первая | [l] последняя | [0] выход${NC}"
        print_line
        echo ""
        
        local start_line=$(( (current_page - 1) * page_size + 1 ))
        local today=$(date '+%Y-%m-%d')
        
        sed -n "${start_line},+$((page_size - 1))p" "$tmp_file" | while IFS='|' read -r datetime direction hash message; do
            datetime=$(echo "$datetime" | xargs)
            direction=$(echo "$direction" | xargs)
            message=$(echo "$message" | xargs)
            
            # Форматируем дату
            local msg_date=$(echo "$datetime" | cut -d' ' -f1)
            local msg_time=$(echo "$datetime" | cut -d' ' -f2)
            
            if [ "$msg_date" == "$today" ]; then
                local time_display="      $msg_time"
            else
                local time_display="$msg_date $msg_time"
            fi
            
            if [ "$direction" == "IN" ]; then
                echo -e "${GRAY}$time_display${NC}"
                echo -e "  ${LIGHT_BLUE}👤 $nick:${NC} $message"
            else
                echo -e "${GRAY}$time_display${NC}"
                echo -e "  ${LIGHT_GREEN}🤖 Bot:${NC} $message"
            fi
            echo ""
        done
        
        echo ""
        print_line
        echo -ne "${CYAN}Выбор: ${NC}"
        local choice=$(read_key)
        
        if [[ "$choice" == "ESC" ]] || [[ "$choice" == "0" ]]; then
            rm -f "$tmp_file"
            return
        fi
        
        choice=$(convert_ru_to_en "$choice")
        
        case $choice in
            n|N) 
                if [ "$current_page" -lt "$total_pages" ]; then
                    ((current_page++))
                fi
                ;;
            p|P)
                if [ "$current_page" -gt 1 ]; then
                    ((current_page--))
                fi
                ;;
            f|F) current_page=1 ;;
            l|L) current_page=$total_pages ;;
            *) ;;
        esac
    done
}

# Поиск по нику
search_by_nick() {
    local msg_log="/home/user/ollama-bot/logs/messages.log"
    
    echo ""
    echo -e "${CYAN}═══ ПОИСК ПО НИКУ ═══${NC}"
    echo ""
    echo -e "${GRAY}(Enter или 0 = отмена)${NC}"
    echo ""
    
    echo -ne "${WHITE}Ник: ${NC}"
    read -r search_nick
    
    if [ -z "$search_nick" ] || [ "$search_nick" == "0" ]; then
        echo -e "${GRAY}Отменено${NC}"
        sleep 0.5
        return
    fi
    
    print_header
    echo -e "${WHITE}${BOLD}  🔍 РЕЗУЛЬТАТЫ ПОИСКА: '$search_nick'${NC}"
    print_line
    echo ""
    
    # Ищем адреса по нику в data.cfg
    local found=0
    while IFS='=' read -r hash nick_found; do
        hash=$(echo "$hash" | xargs)
        nick_found=$(echo "$nick_found" | xargs)
        
        if echo "$nick_found" | grep -qi "$search_nick"; then
            echo -e "${WHITE}Найден: ${LIGHT_CYAN}$nick_found${NC} ${GRAY}[$hash]${NC}"
            echo ""
            
            # Показываем последние сообщения
            if [ -f "$msg_log" ]; then
                local count=$(grep -c "$hash" "$msg_log" 2>/dev/null || echo "0")
                echo -e "${GRAY}Сообщений: $count${NC}"
                echo ""
                
                grep "$hash" "$msg_log" | tail -10 | while IFS='|' read -r datetime direction h message; do
                    datetime=$(echo "$datetime" | xargs)
                    direction=$(echo "$direction" | xargs)
                    message=$(echo "$message" | xargs | cut -c1-60)
                    
                    if [ "$direction" == "IN" ]; then
                        echo -e "  ${LIGHT_BLUE}→${NC} $datetime: $message"
                    else
                        echo -e "  ${LIGHT_GREEN}←${NC} $datetime: $message"
                    fi
                done
            fi
            
            echo ""
            print_line
            found=1
        fi
    done < <(grep -v '^\[' /root/.config/lxmf_distribution_group_extended/data.cfg 2>/dev/null | grep '=')
    
    if [ $found -eq 0 ]; then
        echo -e "${YELLOW}Ничего не найдено по запросу '$search_nick'${NC}"
    fi
    
    press_enter
}

# Поиск по адресу
search_by_address() {
    local msg_log="/home/user/ollama-bot/logs/messages.log"
    
    echo ""
    echo -e "${CYAN}═══ ПОИСК ПО АДРЕСУ ═══${NC}"
    echo ""
    echo -e "${GRAY}Введи полный адрес или часть (минимум 8 символов)${NC}"
    echo -e "${GRAY}(Enter или 0 = отмена)${NC}"
    echo ""
    
    echo -ne "${WHITE}Адрес: ${NC}"
    read -r search_addr
    
    if [ -z "$search_addr" ] || [ "$search_addr" == "0" ]; then
        echo -e "${GRAY}Отменено${NC}"
        sleep 0.5
        return
    fi
    
    if [ ${#search_addr} -lt 8 ]; then
        echo -e "${RED}Минимум 8 символов!${NC}"
        sleep 1
        return
    fi
    
    print_header
    echo -e "${WHITE}${BOLD}  🔎 РЕЗУЛЬТАТЫ ПОИСКА: '$search_addr'${NC}"
    print_line
    echo ""
    
    if [ ! -f "$msg_log" ]; then
        echo -e "${YELLOW}Лог не найден${NC}"
        press_enter
        return
    fi
    
    # Ищем по адресу
    local matches=$(grep -i "$search_addr" "$msg_log" 2>/dev/null | head -1 | cut -d'|' -f3 | xargs)
    
    if [ -n "$matches" ]; then
        local nick=$(get_user_nick "$matches")
        local count=$(grep -c "$matches" "$msg_log" 2>/dev/null || echo "0")
        
        echo -e "${WHITE}Найден: ${LIGHT_CYAN}$nick${NC}"
        echo -e "${GRAY}Адрес: $matches${NC}"
        echo -e "${GRAY}Сообщений: $count${NC}"
        echo ""
        print_line
        echo ""
        
        # Показываем последние сообщения
        grep "$matches" "$msg_log" | tail -20 | while IFS='|' read -r datetime direction hash message; do
            datetime=$(echo "$datetime" | xargs)
            direction=$(echo "$direction" | xargs)
            message=$(echo "$message" | xargs)
            
            if [ "$direction" == "IN" ]; then
                echo -e "${GRAY}$datetime${NC}"
                echo -e "  ${LIGHT_BLUE}👤 $nick:${NC} $message"
            else
                echo -e "${GRAY}$datetime${NC}"
                echo -e "  ${LIGHT_GREEN}🤖 Bot:${NC} $message"
            fi
            echo ""
        done
    else
        echo -e "${YELLOW}Ничего не найдено по адресу '$search_addr'${NC}"
    fi
    
    press_enter
}

# Показать все сообщения с пагинацией
show_last_messages() {
    local msg_log="/home/user/ollama-bot/logs/messages.log"
    local page_size=20
    
    if [ ! -f "$msg_log" ]; then
        echo -e "${YELLOW}Лог не найден${NC}"
        press_enter
        return
    fi
    
    local total_lines=$(wc -l < "$msg_log")
    if [ "$total_lines" -eq 0 ]; then
        echo -e "${YELLOW}Лог пуст${NC}"
        press_enter
        return
    fi
    
    local total_pages=$(( (total_lines + page_size - 1) / page_size ))
    local current_page=$total_pages  # Начинаем с последней страницы
    
    while true; do
        clear
        echo ""
        echo -e "${CYAN}═══ 📜 ВСЕ СООБЩЕНИЯ ═══${NC}"
        echo -e "${GRAY}Всего: $total_lines сообщений | Страница $current_page/$total_pages${NC}"
        echo -e "${GRAY}[n] след. | [p] пред. | [f] первая | [l] последняя | [0] выход${NC}"
        print_line
        echo ""
        
        local start_line=$(( (current_page - 1) * page_size + 1 ))
        
        sed -n "${start_line},+$((page_size - 1))p" "$msg_log" | while IFS='|' read -r datetime direction hash message; do
            datetime=$(echo "$datetime" | xargs)
            direction=$(echo "$direction" | xargs)
            hash=$(echo "$hash" | xargs)
            message=$(echo "$message" | xargs)
            
            local nick=$(get_user_nick "$hash")
            
            # Форматируем дату
            local msg_date=$(echo "$datetime" | cut -d' ' -f1)
            local msg_time=$(echo "$datetime" | cut -d' ' -f2 | cut -c1-5)
            
            if [ "$direction" == "IN" ]; then
                echo -e "${GRAY}$msg_date $msg_time${NC} ${LIGHT_BLUE}$nick${NC} ${GRAY}[$hash]${NC}"
                echo -e "  ${GRAY}→${NC} $message"
            else
                echo -e "${GRAY}$msg_date $msg_time${NC} ${LIGHT_GREEN}Bot${NC} ${GRAY}→ $nick${NC}"
                echo -e "  ${GRAY}←${NC} $message"
            fi
            echo ""
        done
        
        echo ""
        print_line
        echo -ne "${CYAN}Выбор: ${NC}"
        local choice=$(read_key)
        
        if [[ "$choice" == "ESC" ]] || [[ "$choice" == "0" ]]; then
            return
        fi
        
        choice=$(convert_ru_to_en "$choice")
        
        case $choice in
            n|N) 
                if [ "$current_page" -lt "$total_pages" ]; then
                    ((current_page++))
                fi
                ;;
            p|P)
                if [ "$current_page" -gt 1 ]; then
                    ((current_page--))
                fi
                ;;
            f|F) current_page=1 ;;
            l|L) current_page=$total_pages ;;
            *) ;;
        esac
    done
}

