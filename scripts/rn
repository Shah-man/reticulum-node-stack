#!/bin/bash
# Перезапускаем себя через sudo если запущены не от root
if [ "$EUID" -ne 0 ]; then
    exec sudo "$0" "$@"
fi
# ╔═══════════════════════════════════════════════════════════════╗
# ║                    RETICULUM CONTROL                          ║
# ║         Управление всеми сервисами Reticulum сети             ║
# ╚═══════════════════════════════════════════════════════════════╝
#
# Установка: sudo cp rn /usr/local/bin/ && sudo chmod +x /usr/local/bin/rn
# Запуск: rn (или кт на русской раскладке)
#

# ══════════════════════════════════════════════════════════════════
# КОНФИГУРАЦИЯ
# ══════════════════════════════════════════════════════════════════

VENV_PATH="/home/user/reticulum/venv"
WORK_DIR="/home/user/reticulum"
LOG_FILE="/home/user/reticulum/logs/rn_control.log"
PAGES_PATH="/root/.nomadnetwork/storage/pages"
PIN_FILE="/root/.rn_pin"
SSH_PORT=40904

# Все сервисы (показываются в меню и считаются для статуса)
SERVICES=(
    "reticulum.service"
    "nomadnet.service"
    "surgut_group.service"
    "surgutbot86.service"
    "messageboard.service"
)

# Сервисы для анонса (без reticulum и messageboard — они не анонсят)
ANNOUNCE_SERVICES=(
    "nomadnet.service"
    "surgut_group.service"
    "surgutbot86.service"
)

# Динамическое чтение имён группы и бота
get_group_name() {
    local cfg="/root/.config/lxmf_distribution_group_extended/config.cfg.owr"
    local name=""
    if [[ -f "$cfg" ]]; then
        name="$(grep -E '^\s*display_name\s*=' "$cfg" | head -n1 | cut -d= -f2- | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    fi
    echo "${name:-LXMF Group}"
}

get_bot_name() {
    local env="/home/user/ollama-bot/.env"
    local name=""
    if [[ -f "$env" ]]; then
        name="$(grep -E '^\s*BOT_NAME\s*=' "$env" | head -n1 | cut -d= -f2- | sed 's/^[[:space:]]*//;s/[[:space:]]*$//;s/^"//;s/"$//')"
    fi
    echo "${name:-Bot}"
}

declare -A SERVICE_NAMES=(
    ["reticulum.service"]="🌐 Reticulum Stack"
    ["nomadnet.service"]="📡 NomadNet Node"
    ["surgut_group.service"]="👥 $(get_group_name)"
    ["lxmf_group.service"]="👥 $(get_group_name)"
    ["surgutbot86.service"]="🤖 $(get_bot_name)"
    ["messageboard.service"]="📋 messageboard"
)

# Путь к доске объявлений
BOARD_PATH="/root/.nomadmb/storage/board"

# Пути к данным группы и бота
GROUP_CONFIG="/root/.config/lxmf_distribution_group_extended"
BOT_DATA="/home/user/ollama-bot/bot_data"

# ══════════════════════════════════════════════════════════════════
# ЦВЕТА И ФОРМАТИРОВАНИЕ
# ══════════════════════════════════════════════════════════════════

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
GRAY='\033[0;90m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# Дополнительные оттенки для меню
LIGHT_BLUE='\033[1;34m'
LIGHT_GREEN='\033[1;32m'
LIGHT_PURPLE='\033[1;35m'
ORANGE='\033[0;33m'
LIGHT_CYAN='\033[1;36m'
LIGHT_RED='\033[1;31m'
PINK='\033[1;35m'

# ══════════════════════════════════════════════════════════════════
# ВСПОМОГАТЕЛЬНАЯ ФУНКЦИЯ: НИК ПОЛЬЗОВАТЕЛЯ
# ══════════════════════════════════════════════════════════════════

# Получить ник пользователя по хэшу
get_user_nick() {
    local hash="$1"
    local nick=$(grep "$hash" /root/.config/lxmf_distribution_group_extended/data.cfg 2>/dev/null | head -1 | cut -d'=' -f2 | tr -d ' ')
    if [ -z "$nick" ]; then
        echo "$hash"
    else
        echo "$nick"
    fi
}

# ══════════════════════════════════════════════════════════════════
# PIN-КОД ЗАЩИТА
# ══════════════════════════════════════════════════════════════════

# Проверка существования PIN
check_pin_exists() {
    [ -f "$PIN_FILE" ]
}

# Установка нового PIN
setup_pin() {
    echo ""
    echo -e "${CYAN}═══ УСТАНОВКА PIN-КОДА ═══${NC}"
    echo ""
    echo -e "${GRAY}PIN защищает опасные действия (остановка сервисов, чаты, отправка)${NC}"
    echo ""
    
    while true; do
        echo -ne "${WHITE}Введите 4-значный PIN: ${NC}"
        read -s pin1
        echo ""
        
        if [[ ! "$pin1" =~ ^[0-9]{4}$ ]]; then
            echo -e "${RED}PIN должен быть 4 цифры!${NC}"
            continue
        fi
        
        echo -ne "${WHITE}Повторите PIN: ${NC}"
        read -s pin2
        echo ""
        
        if [ "$pin1" != "$pin2" ]; then
            echo -e "${RED}PIN не совпадает!${NC}"
            continue
        fi
        
        echo "$pin1" > "$PIN_FILE"
        chmod 600 "$PIN_FILE"
        echo -e "${GREEN}✓ PIN установлен!${NC}"
        sleep 1
        break
    done
}

# Проверка PIN
verify_pin() {
    local action="$1"
    
    if ! check_pin_exists; then
        return 0  # Если PIN не установлен — пропускаем
    fi
    
    local stored_pin=$(cat "$PIN_FILE")
    
    echo ""
    echo -ne "${YELLOW}🔐 PIN для '$action': ${NC}"
    read -s entered_pin
    echo ""
    
    if [ "$entered_pin" == "$stored_pin" ]; then
        return 0
    else
        echo -e "${RED}✗ Неверный PIN!${NC}"
        sleep 1
        return 1
    fi
}

# Сброс PIN
reset_pin() {
    if ! check_pin_exists; then
        echo -e "${YELLOW}PIN не установлен${NC}"
        press_enter
        return
    fi
    
    if ! verify_pin "сброс PIN"; then
        return
    fi
    
    echo ""
    echo -ne "${YELLOW}Удалить PIN? (y = да): ${NC}"
    read -r confirm
    
    if [[ "$confirm" =~ ^[YyДд]$ ]]; then
        rm -f "$PIN_FILE"
        echo -e "${GREEN}✓ PIN удалён!${NC}"
    else
        echo -e "${GRAY}Отменено${NC}"
    fi
    press_enter
}

# Изменение PIN
change_pin() {
    if check_pin_exists; then
        if ! verify_pin "изменение PIN"; then
            return
        fi
    fi
    setup_pin
    press_enter
}

# ══════════════════════════════════════════════════════════════════
# ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
# ══════════════════════════════════════════════════════════════════

log_action() {
    local msg="$1"
    mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $msg" >> "$LOG_FILE"
}

print_header() {
    clear
    echo ""
    echo -e "${CYAN}════════════════════════════════════${NC}"
    echo -e "${CYAN}${BOLD}      RETICULUM CONTROL${NC}"
    echo -e "${CYAN}════════════════════════════════════${NC}"
    echo -e "      ${GRAY}$(date '+%d.%m.%Y %H:%M:%S')${NC}"
    echo ""
}

print_line() {
    echo -e "${GRAY}────────────────────────────────────${NC}"
}

press_enter() {
    echo ""
    echo -e "${GRAY}Нажми Enter чтобы продолжить...${NC}"
    read
}

# Чтение ввода с поддержкой ESC
read_choice() {
    local choice=""
    
    # Читаем один символ
    IFS= read -rsn1 choice
    
    # Проверяем на ESC последовательность
    if [[ "$choice" == $'\e' ]]; then
        # Читаем возможные дополнительные символы (для стрелок и т.д.)
        read -rsn2 -t 0.1 extra
        if [ -z "$extra" ]; then
            # Чистый ESC
            echo "ESC"
            return
        fi
    fi
    
    # Если Enter (пустой ввод после первого символа)
    if [ -z "$choice" ]; then
        echo ""
        return
    fi
    
    # Если цифра или буква — читаем до Enter
    if [[ "$choice" =~ [0-9a-zA-Zа-яА-Я] ]]; then
        local rest=""
        read -r rest
        echo "${choice}${rest}"
        return
    fi
    
    echo "$choice"
}

# Мгновенное чтение одного символа (для меню)
read_key() {
    local key=""
    IFS= read -rsn1 key
    
    # Проверяем ESC
    if [[ "$key" == $'\e' ]]; then
        read -rsn2 -t 0.1 extra
        if [ -z "$extra" ]; then
            echo "ESC"
            return
        fi
    fi
    
    echo "$key"
}

# Конвертация русской раскладки в английскую
convert_ru_to_en() {
    local input="$1"
    echo "$input" | sed 'y/йцукенгшщзхъфывапролджэячсмитьбюЙЦУКЕНГШЩЗХЪФЫВАПРОЛДЖЭЯЧСМИТЬБЮ/qwertyuiop[]asdfghjkl;'\''zxcvbnm,.QWERTYUIOP[]ASDFGHJKL;'\''ZXCVBNM,./'
}

# Проверка статуса сервиса
get_service_status() {
    local service=$1
    if systemctl is-active --quiet "$service" 2>/dev/null; then
        echo "active"
    else
        echo "inactive"
    fi
}

# Красивый вывод статуса
print_service_status() {
    local service=$1
    local name="${SERVICE_NAMES[$service]:-$service}"
    local status=$(get_service_status "$service")
    
    if [ "$status" = "active" ]; then
        echo -e "  ${GREEN}●${NC} $name ${GREEN}[работает]${NC}"
    else
        echo -e "  ${RED}●${NC} $name ${RED}[остановлен]${NC}"
    fi
}

# Проверка venv
check_venv_active() {
    if [[ "$VIRTUAL_ENV" == "$VENV_PATH" ]]; then
        return 0
    else
        return 1
    fi
}

# ══════════════════════════════════════════════════════════════════
# ФУНКЦИИ УПРАВЛЕНИЯ СЕРВИСАМИ
# ══════════════════════════════════════════════════════════════════

start_service() {
    local service=$1
    local name="${SERVICE_NAMES[$service]:-$service}"
    echo -e "${YELLOW}▶${NC} Запускаю $name..."
    sudo systemctl start "$service"
    sleep 1
    if [ "$(get_service_status "$service")" = "active" ]; then
        echo -e "${GREEN}✓${NC} $name запущен"
        log_action "STARTED: $service"
    else
        echo -e "${RED}✗${NC} Ошибка запуска $name"
        log_action "FAILED TO START: $service"
    fi
}

stop_service() {
    local service=$1
    local name="${SERVICE_NAMES[$service]:-$service}"
    echo -e "${YELLOW}■${NC} Останавливаю $name..."
    sudo systemctl stop "$service"
    sleep 1
    if [ "$(get_service_status "$service")" = "inactive" ]; then
        echo -e "${GREEN}✓${NC} $name остановлен"
        log_action "STOPPED: $service"
    else
        echo -e "${RED}✗${NC} Ошибка остановки $name"
        log_action "FAILED TO STOP: $service"
    fi
}

restart_service() {
    local service=$1
    local name="${SERVICE_NAMES[$service]:-$service}"
    echo -e "${YELLOW}↻${NC} Перезапускаю $name..."
    sudo systemctl restart "$service"
    sleep 2
    if [ "$(get_service_status "$service")" = "active" ]; then
        echo -e "${GREEN}✓${NC} $name перезапущен"
        log_action "RESTARTED: $service"
    else
        echo -e "${RED}✗${NC} Ошибка перезапуска $name"
        log_action "FAILED TO RESTART: $service"
    fi
}

# Запуск всех сервисов
start_all() {
    echo -e "\n${CYAN}═══ ЗАПУСК ВСЕХ СЕРВИСОВ ═══${NC}\n"
    log_action "=== STARTING ALL SERVICES ==="
    for service in "${SERVICES[@]}"; do
        start_service "$service"
    done
    echo ""
    echo -e "${GREEN}✓ Все сервисы запущены!${NC}"
    press_enter
}

# Остановка всех сервисов
stop_all() {
    echo -e "\n${CYAN}═══ ОСТАНОВКА ВСЕХ СЕРВИСОВ ═══${NC}\n"
    log_action "=== STOPPING ALL SERVICES ==="
    # Останавливаем в обратном порядке
    for (( i=${#SERVICES[@]}-1; i>=0; i-- )); do
        stop_service "${SERVICES[i]}"
    done
    echo ""
    echo -e "${GREEN}✓ Все сервисы остановлены!${NC}"
    press_enter
}

# Перезапуск всех сервисов
restart_all() {
    echo -e "\n${CYAN}═══ ПЕРЕЗАПУСК ВСЕХ СЕРВИСОВ ═══${NC}\n"
    log_action "=== RESTARTING ALL SERVICES ==="
    for service in "${SERVICES[@]}"; do
        restart_service "$service"
        if [ "$service" = "reticulum.service" ]; then
            echo -e "${GRAY}⏳ Ожидаю инициализацию Reticulum...${NC}"
            sleep 4
        fi
    done
    echo ""
    echo -e "${GREEN}✓ Все сервисы перезапущены!${NC}"
    press_enter
}

# Анонс всех сервисов (быстрый рестарт 3 главных)
announce_all() {
    echo -e "\n${CYAN}═══ АНОНС ВСЕХ СЕРВИСОВ ═══${NC}\n"
    log_action "=== ANNOUNCING ALL SERVICES ==="
    for service in "${ANNOUNCE_SERVICES[@]}"; do
        local name="${SERVICE_NAMES[$service]:-$service}"
        echo -e "${PURPLE}📢${NC} Анонсирую $name..."
        sudo systemctl restart "$service"
        sleep 0.5
        if [ "$(get_service_status "$service")" = "active" ]; then
            echo -e "${GREEN}✓${NC} $name анонсирован"
            log_action "ANNOUNCED: $service"
        else
            echo -e "${RED}✗${NC} Ошибка анонса $name"
            log_action "FAILED TO ANNOUNCE: $service"
        fi
    done
    echo ""
    echo -e "${GREEN}✓ Все сервисы анонсированы!${NC}"
    press_enter
}

# ══════════════════════════════════════════════════════════════════
# МЕНЮ СТАТУСА
# ══════════════════════════════════════════════════════════════════

show_status() {
    print_header
    echo -e "${WHITE}${BOLD}  СТАТУС СЕРВИСОВ${NC}"
    print_line
    echo ""
    
    local active_count=0
    local total_count=${#SERVICES[@]}
    
    for service in "${SERVICES[@]}"; do
        print_service_status "$service"
        if [ "$(get_service_status "$service")" = "active" ]; then
            ((active_count++))
        fi
    done
    
    echo ""
    print_line
    
    # Статус venv
    if check_venv_active; then
        echo -e "  ${GREEN}●${NC} Virtual Environment ${GREEN}[активен]${NC}"
    else
        echo -e "  ${YELLOW}●${NC} Virtual Environment ${YELLOW}[не активен]${NC}"
    fi
    
    echo ""
    echo -e "  ${CYAN}Работает: ${active_count}/${total_count} сервисов${NC}"
    echo ""
    press_enter
}

# ══════════════════════════════════════════════════════════════════
# ПОДМЕНЮ: СЕРВИСЫ RETICULUM
# ══════════════════════════════════════════════════════════════════

menu_services() {
    while true; do
        print_header
        echo -e "${WHITE}${BOLD}  📡 СЕРВИСЫ RETICULUM${NC}"
        print_line
        echo ""
        
        # Показываем статус каждого сервиса
        for service in "${SERVICES[@]}"; do
            print_service_status "$service"
        done
        
        echo ""
        print_line
        echo -e "  ${LIGHT_CYAN}[1]${NC} ${LIGHT_CYAN}Reticulum Stack${NC}"
        echo -e "  ${LIGHT_BLUE}[2]${NC} ${LIGHT_BLUE}NomadNet${NC}"
        echo -e "  ${LIGHT_PURPLE}[3]${NC} ${LIGHT_PURPLE}$(get_group_name)${NC}"
        echo -e "  ${LIGHT_GREEN}[4]${NC} ${LIGHT_GREEN}$(get_bot_name)${NC}"
        echo -e "  ${PINK}[5]${NC} ${PINK}messageboard${NC}"
        echo -e "  ${CYAN}[6]${NC} ${CYAN}Управление группами${NC}  →"
        print_line
        echo -e "  ${GREEN}[a]${NC} ${GREEN}Запустить ВСЕ${NC}"
        echo -e "  ${RED}[s]${NC} ${RED}Остановить ВСЕ${NC}"
        echo -e "  ${YELLOW}[r]${NC} ${YELLOW}Перезапустить ВСЕ${NC}"
        echo -e "  ${PURPLE}[n]${NC} ${PURPLE}Анонсировать ВСЕ${NC}"
        print_line
        echo -e "  ${GRAY}[0]${NC} ${GRAY}← Назад / Enter${NC}"
        echo ""
        
        echo -ne "${CYAN}Выбор: ${NC}"
        local choice=$(read_key)
        echo "$choice"
        
        # Проверяем ESC
        if [[ "$choice" == "ESC" ]]; then
            return
        fi
        
        # Конвертируем русскую раскладку
        choice=$(convert_ru_to_en "$choice")
        
        case $choice in
            1) menu_single_service "reticulum.service" ;;
            2) menu_nomadnet ;;
            3) menu_group ;;
            4) menu_surgutbot ;;
            5) menu_messageboard ;;
            6) menu_all_groups ;;
            a|A) start_all ;;
            s|S) 
                if verify_pin "остановить ВСЕ"; then
                    stop_all
                fi
                ;;
            r|R) restart_all ;;
            n|N) announce_all ;;
            0) return ;;
            q|Q) echo -e "\n${CYAN}Скрипт завершён.${NC}\n"; exit 0 ;;
            *) ;;
        esac
    done
}

# Меню для одного сервиса
menu_single_service() {
    local service=$1
    local name="${SERVICE_NAMES[$service]:-$service}"
    
    while true; do
        print_header
        echo -e "${WHITE}${BOLD}  $name${NC}"
        print_line
        echo ""
        print_service_status "$service"
        echo ""
        print_line
        echo -e "  ${GREEN}[1]${NC} ▶ ${GREEN}Запустить${NC}"
        echo -e "  ${RED}[2]${NC} ■ ${RED}Остановить${NC}"
        echo -e "  ${YELLOW}[3]${NC} ↻ ${YELLOW}Перезапустить${NC}"
        echo -e "  ${LIGHT_CYAN}[4]${NC} 📜 ${LIGHT_CYAN}Показать логи${NC}"
        echo -e "  ${LIGHT_BLUE}[5]${NC} ℹ️  ${LIGHT_BLUE}Подробный статус${NC}"
        
        # Добавляем интерактивный режим для NomadNet
        if [ "$service" = "nomadnet.service" ]; then
            echo -e "  ${LIGHT_PURPLE}[6]${NC} 🖥️  ${LIGHT_PURPLE}Открыть интерактивно (TUI)${NC}"
        fi
        
        print_line
        echo -e "  ${GRAY}[0]${NC} ${GRAY}← Назад / Enter${NC}"
        echo ""
        
        echo -ne "${CYAN}Выбор: ${NC}"
        local choice=$(read_key)
        echo "$choice"
        
        # Проверяем ESC
        if [[ "$choice" == "ESC" ]]; then
            return
        fi
        
        choice=$(convert_ru_to_en "$choice")
        
        case $choice in
            1) 
                start_service "$service"
                press_enter
                ;;
            2) 
                if verify_pin "остановить $name"; then
                    stop_service "$service"
                    press_enter
                fi
                ;;
            3) 
                restart_service "$service"
                press_enter
                ;;
            4)
                echo ""
                echo -e "${CYAN}═══ ЛОГИ: $name (Ctrl+C для выхода) ═══${NC}"
                echo ""
                sudo journalctl -u "$service" -f --no-pager -n 50
                ;;
            5)
                echo ""
                sudo systemctl status "$service"
                press_enter
                ;;
            6)
                # Интерактивный режим только для NomadNet
                if [ "$service" = "nomadnet.service" ]; then
                    launch_nomadnet_interactive
                fi
                ;;
            0) return ;;
            q|Q) echo -e "\n${CYAN}Скрипт завершён.${NC}\n"; exit 0 ;;
            *) ;;
        esac
    done
}

# ══════════════════════════════════════════════════════════════════
# ПОДМЕНЮ: NOMADNET
# ══════════════════════════════════════════════════════════════════

menu_nomadnet() {
    local service="nomadnet.service"
    local name="${SERVICE_NAMES[$service]}"
    
    while true; do
        print_header
        echo -e "${WHITE}${BOLD}  $name${NC}"
        print_line
        echo ""
        print_service_status "$service"
        echo ""
        print_line
        echo -e "  ${GREEN}[1]${NC} ▶ ${GREEN}Запустить${NC}"
        echo -e "  ${RED}[2]${NC} ■ ${RED}Остановить${NC}"
        echo -e "  ${YELLOW}[3]${NC} ↻ ${YELLOW}Перезапустить${NC}"
        echo -e "  ${LIGHT_CYAN}[4]${NC} 📜 ${LIGHT_CYAN}Показать логи${NC}"
        echo -e "  ${LIGHT_BLUE}[5]${NC} ℹ️  ${LIGHT_BLUE}Подробный статус${NC}"
        echo -e "  ${LIGHT_PURPLE}[6]${NC} 🖥️  ${LIGHT_PURPLE}Открыть интерактивно (TUI)${NC}"
        echo -e "  ${PINK}[7]${NC} 📊 ${PINK}Статистика ноды${NC}"
        print_line
        echo -e "  ${GRAY}[0]${NC} ${GRAY}← Назад / Enter${NC}"
        echo ""
        
        echo -ne "${CYAN}Выбор: ${NC}"
        local choice=$(read_key)
        echo "$choice"
        
        # Проверяем ESC
        if [[ "$choice" == "ESC" ]]; then
            return
        fi
        
        choice=$(convert_ru_to_en "$choice")
        
        case $choice in
            1) start_service "$service"; press_enter ;;
            2) 
                if verify_pin "остановить NomadNet"; then
                    stop_service "$service"
                    press_enter
                fi
                ;;
            3) restart_service "$service"; press_enter ;;
            4)
                echo ""
                echo -e "${CYAN}═══ ЛОГИ: $name (Ctrl+C для выхода) ═══${NC}"
                sudo journalctl -u "$service" -f --no-pager -n 50
                ;;
            5)
                echo ""
                sudo systemctl status "$service"
                press_enter
                ;;
            6) launch_nomadnet_interactive ;;
            7) show_node_stats ;;
            0) return ;;
            q|Q) echo -e "\n${CYAN}Скрипт завершён.${NC}\n"; exit 0 ;;
            *) ;;
        esac
    done
}

# Статистика ноды
show_node_stats() {
    echo ""
    echo -e "${CYAN}═══ СТАТИСТИКА НОДЫ ═══${NC}"
    echo ""
    
    # Парсим peersettings через Python (msgpack формат)
    "$VENV_PATH/bin/python3" -c "
import RNS.vendor.umsgpack as msgpack
import os
from datetime import datetime

peers_file = '/root/.nomadnetwork/storage/peersettings'
if os.path.exists(peers_file):
    with open(peers_file, 'rb') as f:
        data = msgpack.unpack(f)
    
    print(f'  📛 Имя: ${WHITE}{data.get(\"display_name\", \"N/A\")}${NC}')
    print(f'  🔗 Подключений: ${WHITE}{data.get(\"node_connects\", 0)}${NC}')
    print(f'  📄 Запросов страниц: ${WHITE}{data.get(\"served_page_requests\", 0)}${NC}')
    print(f'  📁 Запросов файлов: ${WHITE}{data.get(\"served_file_requests\", 0)}${NC}')
    
    # Последний анонс
    last_announce = data.get('last_announce', 0)
    if last_announce:
        try:
            dt = datetime.fromtimestamp(last_announce)
            print(f'  📢 Последний анонс: ${WHITE}{dt.strftime(\"%Y-%m-%d %H:%M:%S\")}${NC}')
        except:
            pass
" 2>/dev/null
    
    echo ""
    
    # Счётчики посещений страниц
    local counter_dir="/root/.nomadnetwork/storage/counters"
    if [ -d "$counter_dir" ]; then
        echo -e "  ${WHITE}Посещения страниц:${NC}"
        local index_count=$(cat "$counter_dir/index.txt" 2>/dev/null || echo "0")
        local board_count=$(cat "$counter_dir/board.txt" 2>/dev/null || echo "0")
        local guide_count=$(cat "$counter_dir/guide.txt" 2>/dev/null || echo "0")
        echo -e "    📄 index.mu:  ${WHITE}$index_count${NC}"
        echo -e "    📋 board.mu:  ${WHITE}$board_count${NC}"
        echo -e "    📖 guide.mu:  ${WHITE}$guide_count${NC}"
        local total=$((index_count + board_count + guide_count))
        echo -e "    ─────────────────"
        echo -e "    📊 Всего:     ${WHITE}$total${NC}"
        echo ""
    fi
    
    # LXMF Storage
    local lxmf_dir="/root/.nomadnetwork/storage/lxmf"
    if [ -d "$lxmf_dir" ]; then
        local storage_size=$(du -sh "$lxmf_dir" 2>/dev/null | cut -f1)
        echo -e "  💾 LXMF Storage: ${WHITE}$storage_size${NC}"
        
        local msg_count=$(ls -1 "$lxmf_dir/messagestore" 2>/dev/null | wc -l)
        echo -e "  📨 Сообщений в хранилище: ${WHITE}$msg_count${NC}"
    fi
    
    echo ""
    
    # Ресурсы
    local pid=$(systemctl show -p MainPID nomadnet.service 2>/dev/null | cut -d= -f2)
    if [ "$pid" != "0" ] && [ -n "$pid" ]; then
        echo -e "  ${GRAY}Ресурсы (PID: $pid):${NC}"
        ps -p "$pid" -o %cpu,%mem,rss --no-headers 2>/dev/null | \
            awk '{printf "  CPU: %s%%  MEM: %s%%  RAM: %.1f MB\n", $1, $2, $3/1024}'
    fi
    
    press_enter
}

