# ============================================================
# SurgutBot86 — Environment Configuration Template
# ============================================================
# Скопируй в .env и заполни своими значениями:
#   cp config.example.env .env
# ============================================================

# Имя бота, отображаемое в LXMF
BOT_NAME=YourBotName

# Хэши администраторов через запятую (получают админ-команды)
ADMIN_HASHES=your_admin_hash_here

# Адрес локального Ollama API
OLLAMA_URL=http://127.0.0.1:11434

# Модель Ollama для генерации ответов
OLLAMA_MODEL=gemma2:9b

# Максимальное число сообщений в истории диалога
MAX_HISTORY=10

# Интервал announce в секундах (43200 = 12 часов)
ANNOUNCE_INTERVAL=43200

# Лимит сообщений от одного пользователя
RATE_LIMIT=5

# Кулдаун между сообщениями в секундах
COOLDOWN=3

# Хэш Propagation Node для доставки сообщений
PROPAGATION_NODE=your_propagation_node_hash_here
